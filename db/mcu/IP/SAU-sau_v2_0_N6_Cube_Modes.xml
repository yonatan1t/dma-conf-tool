        <PossibleValue Value="1" Comment="Non-Secure Callable" Semaphore="NSC6"/>
        <Description>
            Region could be defined as  &lt;br&gt; 
            - Non-Secure &lt;br&gt; 
            - Secure with Non-Secure Callable &lt;br&gt; 
        </Description>
    </RefParameter>
    <RefParameter Name="SAU6_INIT_NSC" Comment="Secure Attribute" DefaultValue="0" Type="list" Visible="false">
        <PossibleValue Value="0" Comment="Non-Secure"/>
        <PossibleValue Value="1" Comment="Non-Secure Callable"/>
    </RefParameter>
    <RefParameter Name="SAU6_INIT_Mode" Comment="Mode" DefaultValue="0" Type="list">
        <Condition Expression="SAU6_INIT_NSC=1" Diagnostic="Non-Secure Callable region address is deduced from linker"/>
        <PossibleValue Value="0" Comment="Static" Semaphore="MODE_STATIC"/>
        <PossibleValue Value="1" Comment="Dynamic" Semaphore="MODE_DYNAMIC_6" Condition="(MODE_DYNAMIC_0|MODE_DYNAMIC_1|MODE_DYNAMIC_2|MODE_DYNAMIC_3|MODE_DYNAMIC_4|MODE_DYNAMIC_5|MODE_DYNAMIC_7)" Action="remove"/>
    </RefParameter>
    <RefParameter Name="SAU6_End_Address" Comment="End Address"  DefaultValue="_eNSCVeneer " Type="string">
        <Condition Expression="NSC6 &amp; MODE_DYNAMIC_6" Diagnostic=""/>
        <Description>
            Size of this region &lt;br&gt;
            Used to compute the end address of this region
        </Description>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_REGION" Comment="Enable this region" DefaultValue="0" Type="list">
        <PossibleValue Value="1" Comment="Yes" Semaphore="S_SAU7_Activated"/>
        <PossibleValue Value="0" Comment="No"/>
        <Description>
            Activate the region initialisation. If no initialisation all fields are forced to 0x00
        </Description>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_START" Comment="Start Address" DefaultValue="0x00000000" Min="0x00000000" Max ="0xFFFFFFE0" Type="hex">
        <Condition Expression="S_SAU7_Activated &amp; !NSC7| (NSC7 &amp; !MODE_DYNAMIC_7)" Diagnostic=""/>
        <Description>
            Start address of this region
        </Description>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_START_DYNAMIC" Comment="Start Address" DefaultValue="_sNSCVeneer" Type="string">
        <Condition Expression="NSC7 &amp; MODE_DYNAMIC_7 " Diagnostic=""/>
        <Description>
            Start address of this region
        </Description>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_START" Comment="Start Address" DefaultValue="0x00000000" Min="0x00000000" Max ="0xFFFFFFE0" Type="hex" Visible="false"/>
    <RefParameter Name="SAU7_INIT_SIZE" Comment="Block Size" Min="0x20" Max ="0xFFFFFFFF" DefaultValue="0x20" Type="hex">
        <Condition Expression="S_SAU7_Activated &amp; !NSC7| (NSC7 &amp; !MODE_DYNAMIC_7)" Diagnostic=""/>
        <Description>
            Size of this region &lt;br&gt; 
            Used to compute the end address of this region
        </Description>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_SIZE" Comment="Block Size" Min="0x00000000" Max ="0xFFFFFFFF" DefaultValue="0x00000000" Type="hex" Visible="false"/>
    <RefParameter Name="SAU7_INIT_END" Comment="End Address" DefaultValue="=SAU7_INIT_START+SAU7_INIT_SIZE-1" Type="hex" Visible="false">
        <Condition Expression="S_SAU7_Activated" Diagnostic=""/>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_END" Comment="End Address" DefaultValue="0x00000000" Type="hex" Visible="false"/>
    <RefParameter Name="SAU7_INIT_NSC" Comment="Secure Attribute" DefaultValue="0" Type="list">
        <Condition Expression="S_SAU7_Activated" Diagnostic=""/>
        <PossibleValue Value="0" Comment="Non-Secure"/>
        <PossibleValue Value="1" Comment="Non-Secure Callable" Semaphore="NSC7"/>
        <Description>
            Region could be defined as  &lt;br&gt; 
            - Non-Secure &lt;br&gt; 
            - Secure with Non-Secure Callable &lt;br&gt; 
        </Description>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_NSC" Comment="Secure Attribute" DefaultValue="0" Type="list" Visible="false">
        <PossibleValue Value="0" Comment="Non-Secure"/>
        <PossibleValue Value="1" Comment="Non-Secure Callable"/>
    </RefParameter>
    <RefParameter Name="SAU7_INIT_Mode" Comment="Mode" DefaultValue="0" Type="list">
        <Condition Expression="SAU7_INIT_NSC=1" Diagnostic="Non-Secure Callable region address is deduced from linker"/>
        <PossibleValue Value="0" Comment="Static" Semaphore="MODE_STATIC"/>
        <PossibleValue Value="1" Comment="Dynamic" Semaphore="MODE_DYNAMIC_7" Condition="(MODE_DYNAMIC_0|MODE_DYNAMIC_1|MODE_DYNAMIC_2|MODE_DYNAMIC_3|MODE_DYNAMIC_4|MODE_DYNAMIC_5|MODE_DYNAMIC_6)" Action="remove"/>
    </RefParameter>
    <RefParameter Name="SAU7_End_Address" Comment="End Address"  DefaultValue="_eNSCVeneer " Type="string">
        <Condition Expression="NSC7 &amp; MODE_DYNAMIC_7" Diagnostic=""/>
        <Description>
            Size of this region &lt;br&gt;
            Used to compute the end address of this region
        </Description>
    </RefParameter>
