            </CallLibMethod>
        </IFCondition>
        <ImplementCallBack Name="HAL_RAMCFG_MspInit"/>
        <ImplementCallBack Name="HAL_RAMCFG_MspDeInit"/>
    </RefConfig>
    
    <RefConfig Name="Ramcfg1_DeInit">
        <CallLibMethod Name="HAL_RAMCFG_DeInit">
            <MethodArg Name="hramcfg" ParameterName="hramcfg_SRAM1"/>
        </CallLibMethod>
    </RefConfig>
    
