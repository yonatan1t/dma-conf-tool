	/* USER CODE BEGIN pinctrl */
usart2_pins_mx:usart2_mx-0{

	pins1{
		pinmux = <STM32_PINMUX('A', 4, AF6)>;
		bias-disable;
		drive-push-pull;
		slew-rate = <0>;
	};

	pins2{
		pinmux = <STM32_PINMUX('A', 8, AF8)>;
		bias-disable;
		drive-push-pull;
	};
};
	/* USER CODE END pinctrl */

&usart2 {
	pinctrl-names = "default";
	pinctrl-0 = <&usart2_pins_mx>;
	status = "okay";
};

&usart2_pins_mx{
 	bootph-all;

  	pins1{
 		bootph-all;
  	};

  	pins2{
 		bootph-all;
  	};
};
