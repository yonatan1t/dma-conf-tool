			regu = <&vddcore>;
			scmi-id = <VOLTD_SCMI_STPMIC_BUCK1>;
		};

		scmi_vdd3v3_usb:voltd-vdd3v3-usb{
			compatible = "st,stm32mp25-scmi-regu";
