		};
		scmi_vddio1:voltd-vddio1 {
			compatible = "st,stm32mp25-scmi-regu";
			regu = <&vddio1>;
			scmi-id = <VOLTD_SCMI_VDDIO1>;
		};
		scmi_vddio2:voltd-vddio2 {
			compatible = "st,stm32mp25-scmi-regu";
			regu = <&vddio2>;
