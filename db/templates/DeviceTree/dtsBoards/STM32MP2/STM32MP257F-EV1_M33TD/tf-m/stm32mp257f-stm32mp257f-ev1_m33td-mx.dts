		};
		scmi_vddcore:voltd-vddcore {
			compatible = "st,stm32mp25-scmi-regu";
			regu = <&vddcore>;
			scmi-id = <VOLTD_SCMI_STPMIC2_BUCK2>;
		};
		scmi_v1v8:voltd-v1v8 {
			compatible = "st,stm32mp25-scmi-regu";
			regu = <&v1v8>;
			scmi-id = <VOLTD_SCMI_STPMIC2_BUCK5>;
		};
		scmi_v3v3:voltd-v3v3 {
			compatible = "st,stm32mp25-scmi-regu";
			regu = <&v3v3>;
			scmi-id = <VOLTD_SCMI_STPMIC2_BUCK7>;
