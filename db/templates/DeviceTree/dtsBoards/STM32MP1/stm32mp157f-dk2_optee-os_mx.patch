/* USER CODE BEGIN pinctrl */
uart4_pins_mx: uart4_mx-0 {
	pins1 {
		pinmux = <STM32_PINMUX_NSEC('B', 2, AF8)>; /* UART4_RX */
		bias-disable;
	};
	pins2 {
		pinmux = <STM32_PINMUX_NSEC('G', 11, AF6)>; /* UART4_TX */
		bias-disable;
		drive-push-pull;
		slew-rate = <0>;
	};
uart4_idle_pins_mx: uart4-idle-0 {
		pins1 {
			pinmux = <STM32_PINMUX_NSEC('G', 11, ANALOG)>; /* UART4_TX */
		};
		pins2 {
			pinmux = <STM32_PINMUX_NSEC('B', 2, AF8)>; /* UART4_RX */
			bias-disable;
		};
	};

uart4_sleep_pins_mx: uart4-sleep-0 {
		pins {
			pinmux = <STM32_PINMUX_NSEC('G', 11, ANALOG)>, /* UART4_TX */
				 <STM32_PINMUX_NSEC('B', 2, ANALOG)>; /* UART4_RX */
		};
	};
};
/* USER CODE END pinctrl */

&uart4 {
	pinctrl-names = "default", "sleep", "idle";
	pinctrl-0 = <&uart4_pins_mx>;
	pinctrl-1 = <&uart4_sleep_pins_mx>;
	pinctrl-2 = <&uart4_idle_pins_mx>;
	/delete-property/dmas;
	/delete-property/dma-names;
	status = "okay";
};
